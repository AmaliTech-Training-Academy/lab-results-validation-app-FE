#!/bin/sh
# Pre-commit hook
# Validates branch naming conventions and runs code quality checks

set -e

branch=$(git rev-parse --abbrev-ref HEAD)

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Branch naming validation
# Valid patterns: main, develop, feature/*, feat/*, chore/*, hotfix/*, fix/*, bugfix/*
# Branch names must be lowercase with hyphens
valid_branch_pattern="^(main|develop|feature\/[a-z0-9-]+|feat\/[a-z0-9-]+|chore\/[a-z0-9-]+|hotfix\/[a-z0-9-]+|fix\/[a-z0-9-]+|bugfix\/[a-z0-9-]+)$"

if ! echo "$branch" | grep -qE "$valid_branch_pattern"; then
    echo "${RED}╔════════════════════════════════════════════════════════════╗${NC}"
    echo "${RED}║           BRANCH NAME VALIDATION FAILED                    ║${NC}"
    echo "${RED}╚════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    echo "${YELLOW}Valid branch patterns:${NC}"
    echo "  • main"
    echo "  • develop"
    echo "  • feature/<description>"
    echo "  • feat/<description>"
    echo "  • chore/<description>"
    echo "  • hotfix/<description>"
    echo "  • fix/<description>"
    echo "  • bugfix/<description>"
    echo ""
    echo "${YELLOW}Rules:${NC}"
    echo "  • Branch names must be lowercase"
    echo "  • Use hyphens to separate words"
    echo "  • Be descriptive and concise"
    echo ""
    echo "${YELLOW}Valid examples:${NC}"
    echo "  feature/user-authentication"
    echo "  feat/add-login-endpoint"
    echo "  chore/update-dependencies"
    echo "  hotfix/critical-security-patch"
    echo "  fix/null-pointer-exception"
    echo ""
    echo "${YELLOW}Your branch name:${NC}"
    echo "  $branch"
    echo ""
    exit 1
fi

echo "${GREEN}✓${NC} Branch name validation passed"

# Check for files staged for commit
if git diff --cached --quiet; then
    echo "${YELLOW}WARNING: No files staged for commit${NC}"
    exit 0
fi

echo "${GREEN}✓${NC} Pre-commit checks passed"
