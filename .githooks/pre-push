#!/bin/sh
# Pre-push hook
# Prevents direct pushes to protected branches and runs final validation

set -e

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

protected_branches="^(main|master|develop)$"
current_branch=$(git rev-parse --abbrev-ref HEAD)

# Check if pushing to protected branch
if echo "$current_branch" | grep -qE "$protected_branches"; then
    echo "${RED}╔════════════════════════════════════════════════════════════╗${NC}"
    echo "${RED}║           DIRECT PUSH TO PROTECTED BRANCH BLOCKED         ║${NC}"
    echo "${RED}╚════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    echo "${YELLOW}Protected branches:${NC} main, master, develop"
    echo ""
    echo "${YELLOW}Please use a pull request workflow:${NC}"
    echo "  1. Create a feature branch"
    echo "  2. Push your changes to the feature branch"
    echo "  3. Create a pull request to merge into $current_branch"
    echo ""
    echo "${YELLOW}To bypass this check (not recommended):${NC}"
    echo "  git push --no-verify"
    echo ""
    exit 1
fi

echo "${GREEN}✓${NC} Pre-push validation passed"
echo "${GREEN}✓${NC} Pushing to branch: $current_branch"
