#!/bin/sh
# Commit message validation hook
# Enforces conventional commit format

set -e

commit_msg_file=$1
commit_msg=$(cat "$commit_msg_file")

# Color codes for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Conventional commit pattern
# Format: type(scope): subject
# Subject must be at least 10 characters and start with lowercase
pattern="^(feat|fix|docs|style|refactor|test|chore|hotfix|perf|ci|build|revert)(\([a-z0-9-]+\))?: [a-z].{9,}$"

# Check if commit message matches pattern
if ! echo "$commit_msg" | grep -qE "$pattern"; then
    echo "${RED}╔════════════════════════════════════════════════════════════╗${NC}"
    echo "${RED}║           COMMIT MESSAGE VALIDATION FAILED                 ║${NC}"
    echo "${RED}╚════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    echo "${YELLOW}Required format:${NC}"
    echo "  <type>(scope): <subject>"
    echo ""
    echo "${YELLOW}Rules:${NC}"
    echo "  • Type must be one of: feat, fix, docs, style, refactor, test, chore, hotfix, perf, ci, build, revert"
    echo "  • Scope is optional and must be lowercase with hyphens"
    echo "  • Subject must start with lowercase letter"
    echo "  • Subject must be at least 10 characters"
    echo "  • Use imperative mood (e.g., 'add' not 'added' or 'adds')"
    echo ""
    echo "${YELLOW}Valid examples:${NC}"
    echo "  feat: add user authentication module"
    echo "  fix(api): resolve null pointer exception in user service"
    echo "  chore(deps): update spring boot to version 3.2.0"
    echo "  hotfix: patch critical security vulnerability"
    echo ""
    echo "${YELLOW}Your commit message:${NC}"
    echo "  $commit_msg"
    echo ""
    exit 1
fi

# Additional validation: Check for minimum subject length
subject=$(echo "$commit_msg" | sed -E 's/^[a-z]+(\([a-z0-9-]+\))?: //')
if [ ${#subject} -lt 10 ]; then
    echo "${RED}ERROR: Commit subject too short (minimum 10 characters)${NC}"
    exit 1
fi

# Check for trailing period
if echo "$commit_msg" | grep -qE '\.$'; then
    echo "${YELLOW}WARNING: Commit message should not end with a period${NC}"
fi
